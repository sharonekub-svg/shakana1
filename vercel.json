{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @shakana/mobile build:web",
  "outputDirectory": "apps/mobile/dist",
  "framework": null,
  "installCommand": "echo skip-default-install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
