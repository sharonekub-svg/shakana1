# Copy to .env.deploy and fill in real values, then run scripts/apply-env.sh.
# DO NOT COMMIT .env.deploy.

# ── Supabase ──────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (test or live) ─────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.app.shakana
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_ACCOUNT_ID=

# ── Sentry / PostHog ──────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ── App ───────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_SCHEME=shakana
EXPO_PUBLIC_UNIVERSAL_LINK_HOST=shakana1.vercel.app

# ── Vercel (https://vercel.com/account/tokens) ────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
